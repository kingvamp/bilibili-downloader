{
  "name": "bilibili-downloader",
  "version": "1.0.0",
  "description": "Bilibili Downloader by Enhancer",
  "author": "kingvamp",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "start": "electron .",
    "watch": "vite",
    "pack": "tsc && electron-builder --dir",
    "dist": "tsc && electron-builder"
  },
  "devDependencies": {
    "@types/electron": "^1.6.10",
    "@types/node": "^20.11.0",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^28.1.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.4",
    "typescript": "^5.3.3",
    "vite": "^8.0.2",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "clipboard-event": "^1.6.0",
    "electron-updater": "^6.8.3",
    "qrcode": "^1.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "build": {
    "appId": "com.enhancer.bilibilidownloader",
    "productName": "Bilibili Downloader",
    "compression": "normal",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "kingvamp",
        "repo": "bilibili-downloader"
      }
    ],
    "files": [
      "dist/**/*",
      "index.html",
      "icon.ico"
    ],
    "extraResources": [
      {
        "from": "bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Bilibili Downloader"
    }
  }
}
